# ─────────────────────────────────────────────
# WPP Media Campaign Agent — Environment Variables
# Copy this file to .env.local for local dev
# In production: add these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────

# Meta Ad Account ID (format: act_XXXXXXXXXX)
META_AD_ACCOUNT_ID=act_XXXXXXXXXX

# Meta API Access Token
# ⚠️  MUST be a System User token — never a personal user token.
# System User tokens never expire and are safe for automated tools.
# To create: Business Manager → Settings → Users → System Users
# → Add System User → Generate Token → scopes: ads_management, ads_read
# → Assign your Ad Account to the System User
META_ACCESS_TOKEN=your_system_user_token_here

# Meta API version (check developers.facebook.com/docs/graph-api/changelog)
META_API_VERSION=v25.0

# Vercel KV — auto-populated by Vercel when you add a KV store
# Run: vercel kv create campaign-agent-history
# Then: vercel env pull .env.local
KV_REST_API_URL=your_kv_url
KV_REST_API_TOKEN=your_kv_token
